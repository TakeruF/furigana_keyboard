<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- App theme for the settings activity. DayNight follows the system dark mode. -->
    <style name="Theme.FuriganaKeyboard" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/settings_text</item>
        <item name="colorSecondary">@color/settings_text</item>
        <item name="colorTertiary">@color/settings_text</item>
        <item name="colorControlActivated">@color/settings_text</item>
        <item name="colorControlHighlight">@color/settings_pressed_overlay</item>
        <item name="android:colorAccent">@color/settings_text</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:navigationBarColor">@color/settings_background</item>
        <item name="android:statusBarColor">@color/settings_background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Visual style for the side function keys (layout params set inline). -->
    <style name="SideKey" parent="android:Widget.Button">
        <item name="android:background">@drawable/key_function_background</item>
        <item name="android:textColor">@color/kbd_on_surface</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Green accent key (改行/送信), WeChat style. -->
    <style name="SideKey.Accent">
        <item name="android:background">@drawable/key_accent_background</item>
        <item name="android:textColor">@color/kbd_on_accent</item>
    </style>
</resources>
