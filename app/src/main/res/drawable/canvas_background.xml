<?xml version="1.0" encoding="utf-8"?>
<!-- Handwriting area: flat rounded card, no border (WeChat style). It reads as
     a panel because its color differs from the keyboard background. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/kbd_canvas" />
    <corners android:radius="10dp" />
</shape>
