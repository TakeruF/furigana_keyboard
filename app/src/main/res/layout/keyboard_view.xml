<?xml version="1.0" encoding="utf-8"?>
<!-- Handwriting-first IME layout:
     top    : horizontally scrolling candidates
     middle : wide writing surface with editing and punctuation shortcuts
     bottom : input-mode and system controls
     The symbol / ABC panels are added to panelContainer at runtime. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/kbd_background"
    android:paddingLeft="4dp"
    android:paddingRight="4dp"
    android:paddingBottom="6dp">

    <com.example.furiganakeyboard.view.CandidateBarView
        android:id="@+id/candidateBar"
        android:layout_width="match_parent"
        android:layout_height="60dp" />

    <com.example.furiganakeyboard.view.KeyboardPanelContainer
        android:id="@+id/panelContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/handwritingPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <com.example.furiganakeyboard.view.HandwritingView
                    android:id="@+id/handwritingView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:layout_marginEnd="50dp"
                    android:background="@drawable/canvas_background" />

                <!-- Clears only the ink currently visible on the handwriting pad. -->
                <Button
                    android:id="@+id/keyClearInk"
                    style="@style/SideKey"
                    android:layout_width="64dp"
                    android:layout_height="34dp"
                    android:layout_gravity="start|top"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:contentDescription="@string/key_clear_ink_desc"
                    android:text="@string/key_clear_ink"
                    android:textSize="12sp" />

                <!-- Editing and punctuation shortcuts beside the writing surface. -->
                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="end"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/keyDelete"
                        style="@style/CanvasActionKey"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:contentDescription="@string/key_delete_desc"
                        android:text="@string/key_delete"
                        android:textSize="22sp" />

                    <Button
                        android:id="@+id/keyComma"
                        style="@style/CanvasActionKey"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:contentDescription="@string/key_comma_desc"
                        android:text="@string/key_punctuation_comma"
                        android:textSize="20sp" />

                    <Button
                        android:id="@+id/keyPeriod"
                        style="@style/CanvasActionKey"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:contentDescription="@string/key_period_desc"
                        android:text="@string/key_punctuation_period"
                        android:textSize="20sp" />

                    <Button
                        android:id="@+id/keyQuestion"
                        style="@style/CanvasActionKey"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:contentDescription="@string/key_question_desc"
                        android:text="@string/key_punctuation_question"
                        android:textSize="20sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Requested positions: keyboard picker at far left, ABC at the
                 former language/read-mode position beside the action key. -->
            <LinearLayout
                android:id="@+id/handwritingBottomRow"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/keyKeyboardSwitch"
                    style="@style/KeyboardIconKey"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_margin="1dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/key_keyboard_switch_desc"
                    android:src="@drawable/ic_globe_keyboard" />

                <Button
                    android:id="@+id/keySymbol"
                    style="@style/SideKey"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_margin="1dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/key_symbol"
                    android:text="@string/key_numbers"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/keyEnglish"
                    style="@style/SideKey.Plain"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_margin="1dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/key_english_input_desc"
                    android:text="@string/key_english"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/keySpace"
                    style="@style/SideKey"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_margin="1dp"
                    android:layout_weight="1.7"
                    android:text="@string/key_space"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/keyRomaji"
                    style="@style/SideKey.Plain"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_margin="1dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/key_romaji_input_desc"
                    android:text="@string/key_romaji_japanese"
                    android:textSize="18sp" />

                <Button
                    android:id="@+id/keyEnter"
                    style="@style/SideKey.Accent"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_margin="1dp"
                    android:layout_weight="1.3"
                    android:text="@string/key_enter"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </com.example.furiganakeyboard.view.KeyboardPanelContainer>
</LinearLayout>
